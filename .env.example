# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer le fichier .env

# Base de donnees
DB_PASSWORD=transitea

# JWT - Generer des secrets aleatoires d au moins 256 bits
# Exemple : openssl rand -base64 64
JWT_SECRET_ACCESS=remplacer-par-une-cle-secrete-access-aleatoire-de-256-bits-minimum
JWT_SECRET_REFRESH=remplacer-par-une-cle-secrete-refresh-aleatoire-de-256-bits-minimum

# Gmail SMTP
GMAIL_USERNAME=votre@gmail.com
GMAIL_APP_PASSWORD=votre-mot-de-passe-application-gmail

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_TOKEN=votre-token-whatsapp
WHATSAPP_PHONE_NUMBER_ID=votre-phone-number-id
