# ============================================================
# Fichier modele - Copier en .env et remplir les valeurs
# NE PAS committer le fichier .env
# ============================================================

# --- Base de donnees PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transitea_db
DB_USERNAME=transitea
DB_PASSWORD=REMPLACER_PAR_MOT_DE_PASSE_FORT

# --- JWT ---
# Generer avec PowerShell (Windows) :
#   $rng = New-Object System.Security.Cryptography.RNGCryptoServiceProvider
#   $bytes = New-Object byte[] 64; $rng.GetBytes($bytes)
#   [Convert]::ToBase64String($bytes)
#
# Generer avec Linux/Mac :
#   openssl rand -base64 64
JWT_SECRET_ACCESS=REMPLACER_PAR_SECRET_ACCESS_BASE64_64_OCTETS
JWT_SECRET_REFRESH=REMPLACER_PAR_SECRET_REFRESH_BASE64_64_OCTETS

# --- Spring JPA ---
# update  : met a jour le schema automatiquement (dev)
# validate: valide le schema sans modifier (prod)
# none    : ne touche pas au schema (prod avec migrations Flyway)
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# --- Serveur ---
SERVER_PORT=8080
LOG_LEVEL=INFO

# --- Gmail SMTP (etape 6) ---
# Creer un mot de passe d application dans : myaccount.google.com/apppasswords
GMAIL_USERNAME=votre.adresse@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- WhatsApp Business API Meta (etape 6) ---
# Obtenir depuis : developers.facebook.com -> votre app -> WhatsApp -> Getting Started
WHATSAPP_TOKEN=votre_token_permanent_whatsapp
WHATSAPP_PHONE_NUMBER_ID=votre_phone_number_id

# --- QR Codes (etape 5) ---
# Repertoire de cache sur le serveur
QRCODE_CACHE_PATH=/var/transitea/cache/qrcodes
